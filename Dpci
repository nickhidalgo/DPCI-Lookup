<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DPCI Shelf Life Lookup</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Barlow:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg: #0f1117;
–surface: #181c27;
–card: #1e2336;
–border: #2c3350;
–accent: #f5c842;
–accent-dim: rgba(245,200,66,.12);
–green: #3dd68c;
–green-dim: rgba(61,214,140,.12);
–red: #f5546a;
–red-dim: rgba(245,84,106,.1);
–text: #e8eaf2;
–muted: #6b7294;
–mono: ‘IBM Plex Mono’, monospace;
–sans: ‘Barlow’, sans-serif;
}

body {
background: var(–bg);
color: var(–text);
font-family: var(–sans);
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
padding: 48px 20px 80px;
}

/* noise overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.03’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 0;
}

.wrap {
width: 100%;
max-width: 640px;
position: relative;
z-index: 1;
}

/* header */
header {
margin-bottom: 40px;
text-align: center;
}
.label-tag {
display: inline-flex;
align-items: center;
gap: 8px;
font-family: var(–mono);
font-size: 10px;
font-weight: 500;
letter-spacing: .12em;
text-transform: uppercase;
color: var(–accent);
border: 1px solid rgba(245,200,66,.3);
border-radius: 2px;
padding: 4px 12px;
margin-bottom: 18px;
}
.label-tag::before { content: ‘▶’; font-size: 8px; }
h1 {
font-size: clamp(28px, 6vw, 44px);
font-weight: 700;
letter-spacing: -.02em;
line-height: 1.1;
margin-bottom: 10px;
}
h1 span { color: var(–accent); }
.subtitle {
font-size: 15px;
color: var(–muted);
font-weight: 300;
}

/* search box */
.search-wrap {
position: relative;
margin-bottom: 24px;
}
.search-wrap input {
width: 100%;
background: var(–surface);
border: 1.5px solid var(–border);
border-radius: 6px;
padding: 16px 56px 16px 20px;
font-family: var(–mono);
font-size: 18px;
font-weight: 500;
color: var(–text);
outline: none;
letter-spacing: .06em;
transition: border-color .2s, box-shadow .2s;
}
.search-wrap input::placeholder {
color: var(–muted);
font-weight: 400;
letter-spacing: .04em;
font-size: 14px;
}
.search-wrap input:focus {
border-color: var(–accent);
box-shadow: 0 0 0 3px rgba(245,200,66,.12);
}
.search-icon {
position: absolute;
right: 18px;
top: 50%;
transform: translateY(-50%);
color: var(–muted);
font-size: 18px;
pointer-events: none;
}
.clear-btn {
position: absolute;
right: 18px;
top: 50%;
transform: translateY(-50%);
background: none;
border: none;
color: var(–muted);
font-size: 18px;
cursor: pointer;
padding: 4px;
display: none;
line-height: 1;
border-radius: 4px;
transition: color .15s;
}
.clear-btn:hover { color: var(–text); }

/* result card */
.result-card {
background: var(–card);
border: 1.5px solid var(–border);
border-radius: 8px;
padding: 28px;
margin-bottom: 16px;
animation: slideIn .2s ease;
display: none;
}
@keyframes slideIn {
from { opacity: 0; transform: translateY(-8px); }
to   { opacity: 1; transform: translateY(0); }
}
.result-card.found { border-color: var(–green); background: linear-gradient(135deg, var(–card), rgba(61,214,140,.04)); }
.result-card.not-found { border-color: var(–red); background: linear-gradient(135deg, var(–card), rgba(245,84,106,.04)); }

.result-dpci {
font-family: var(–mono);
font-size: 11px;
font-weight: 500;
letter-spacing: .1em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 10px;
}
.result-name {
font-size: 20px;
font-weight: 600;
line-height: 1.3;
margin-bottom: 20px;
color: var(–text);
}
.shelf-display {
display: flex;
align-items: center;
gap: 16px;
}
.shelf-num {
font-family: var(–mono);
font-size: 52px;
font-weight: 600;
color: var(–green);
line-height: 1;
}
.shelf-label {
display: flex;
flex-direction: column;
gap: 3px;
}
.shelf-label .big { font-size: 16px; font-weight: 600; color: var(–text); }
.shelf-label .small { font-size: 13px; color: var(–muted); font-weight: 300; }

.prelabeled-badge {
display: inline-flex;
align-items: center;
gap: 8px;
background: var(–accent-dim);
border: 1px solid rgba(245,200,66,.3);
border-radius: 4px;
padding: 8px 16px;
font-family: var(–mono);
font-size: 13px;
font-weight: 500;
color: var(–accent);
letter-spacing: .06em;
}

.not-found-msg {
display: flex;
align-items: center;
gap: 12px;
font-size: 15px;
color: var(–red);
font-weight: 400;
}
.not-found-msg .icon { font-size: 22px; }

/* divider */
.divider {
height: 1px;
background: var(–border);
margin: 24px 0;
}

/* all items table */
.table-section { margin-top: 8px; }
.table-header {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 12px;
}
.table-title {
font-family: var(–mono);
font-size: 10px;
font-weight: 600;
letter-spacing: .12em;
text-transform: uppercase;
color: var(–muted);
}
.count-badge {
font-family: var(–mono);
font-size: 10px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 20px;
padding: 2px 10px;
color: var(–muted);
}

.filter-row {
display: flex;
gap: 8px;
margin-bottom: 14px;
flex-wrap: wrap;
}
.filter-btn {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 4px;
padding: 5px 12px;
font-family: var(–mono);
font-size: 10px;
font-weight: 500;
letter-spacing: .06em;
color: var(–muted);
cursor: pointer;
transition: all .15s;
text-transform: uppercase;
}
.filter-btn:hover { border-color: var(–accent); color: var(–accent); }
.filter-btn.active { background: var(–accent-dim); border-color: var(–accent); color: var(–accent); }

.table-wrap {
border: 1px solid var(–border);
border-radius: 6px;
overflow: hidden;
max-height: 420px;
overflow-y: auto;
}
.table-wrap::-webkit-scrollbar { width: 6px; }
.table-wrap::-webkit-scrollbar-track { background: var(–surface); }
.table-wrap::-webkit-scrollbar-thumb { background: var(–border); border-radius: 3px; }

table {
width: 100%;
border-collapse: collapse;
font-size: 13px;
}
thead {
position: sticky;
top: 0;
background: var(–surface);
z-index: 2;
}
th {
font-family: var(–mono);
font-size: 9px;
font-weight: 600;
letter-spacing: .1em;
text-transform: uppercase;
color: var(–muted);
padding: 10px 14px;
text-align: left;
border-bottom: 1px solid var(–border);
}
th:last-child { text-align: right; }
td {
padding: 10px 14px;
border-bottom: 1px solid rgba(44,51,80,.5);
vertical-align: middle;
}
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,.02); cursor: pointer; }
tr.highlighted td { background: rgba(245,200,66,.07); }

.td-dpci {
font-family: var(–mono);
font-size: 11px;
color: var(–muted);
white-space: nowrap;
}
.td-name {
color: var(–text);
font-weight: 400;
line-height: 1.4;
}
.td-days {
text-align: right;
font-family: var(–mono);
font-weight: 600;
white-space: nowrap;
}
.td-days.short { color: var(–red); }
.td-days.medium { color: var(–accent); }
.td-days.long { color: var(–green); }
.td-days.pre {
font-size: 10px;
font-weight: 500;
color: var(–muted);
letter-spacing: .04em;
}

.no-results {
padding: 40px;
text-align: center;
color: var(–muted);
font-size: 14px;
font-style: italic;
}
</style>

</head>
<body>
