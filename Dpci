<script>
const DATA = [
  ["218-13-0254","Iced Strawberry Vanilla Sliced Loaf Cake - 8ct (Val to Spring)","6"],
  ["218-13-0616","FD Brownie Party Platter Pink and Yellow - 16ct","31"],
  ["218-13-0617","FD Spring Mini Frosted Cookies Pink and Yellow - 18ct","29"],
  ["218-13-0618","FD Spring Frosted Cookies Pink and Yellow - 10ct","29"],
  ["218-13-0619","FD Spring Frosted Cookies Pink and Yellow - 18ct","29"],
  ["218-13-0620","St Patty's Chocolate & Vanilla mini cupcakes - 12ct","22"],
  ["218-13-0285","FD Spring Lemon Meringue Cookies - 12.5oz/10ct","15"],
  ["218-13-0621","Strawberry and Lemon Mini Danish 12oz - 10ct","6"],
  ["218-13-0201","FD Strawberry Madeleines","31"],
  ["218-13-0401","FD Strawberry Mini Donuts - 12ct","11"],
  ["218-13-0402","Filled Mini Strawberry Ribbon Cupcakes - 12ct","22"],
  ["218-13-0404","FD Spring Egg and Bunny Shaped Sugar Cookies","181"],
