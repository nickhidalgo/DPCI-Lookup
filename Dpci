  ["218-13-0602","Mini Strawberry Decorated Croissants","15"],
  ["218-13-0603","Lemon Poppyseed Mini Muffins - 9 ct","13"],
  ["218-13-0604","Lemon Shortbread Cookies with Drizzle","61"],
  ["218-13-0613","Spring Hand Decorated Sugar Cookie on a Stick - 1ct","Prelabeled"],
  ["218-13-0218","Lemon Poppyseed Muffin - 4ct","6"],
  ["218-13-0596","Raspberry Filled Danish - 4ct","6"],
  ["218-13-0597","Cream Cheese Filled Danish - 4ct","6"],
  ["218-13-0591","Mini Donut Entertaining Pack","8"],
  ["218-13-0570","Favorite Day Blueberry Danish - 14oz","15"],
  ["218-13-0571","White Chocolate Spring Bunny Sandwich Cookies (4.8oz) - 6ct","Prelabeled"],
  ["218-13-0572","Milk Chocolate Easter Egg & Sprinkles Sandwich Cookies - 6ct","Prelabeled"],
  ["218-13-0573","Individual Milk Graham with Carrot Marshmallow","Prelabeled"],
  ["218-13-0574","Individual White Chocolate Oreo","Prelabeled"],
  ["218-13-0582","Mini Macaron Lemon Raspberry & Strawberry Jam - 4ct","11"],
  ["218-13-0583","Mini Macaron Hazelnut Chocolate & Birthday Cake - 4ct","11"],
  ["218-13-0584","Spring Vanilla Cake Pop Purple and Yellow with Pink Drizzle - 4ct","11"],
  ["218-13-0588","Chocolate Tuxedo Mini Layer Cakes","61"],
  ["218-13-0589","Lemon Linzer Tarts","61"],
  ["218-13-0590","Spring Sugar Cookies - 6oz","181"],
  ["218-13-0592","Gluten Free Strawberry Snack Bites - 8ct 8oz","45"],
  ["218-13-0608","Pastel M&M Cookie with White Chocolate Chunks - 12.5oz/10ct","15"],
  ["218-13-0609","Strawberries and Cream Cookie - 12.5oz/10ct","15"],
  ["218-13-0610","Spring Chocolate Fudge Brownie - 8ct","15"],
  ["218-13-0611","Easter Bunny Snack Mix - 7oz (VERSION 1)","Prelabeled"],
  ["218-13-0614","Spring Carrot Cupcakes - 4ct","6"],
  ["218-13-0615","Spring Cake Bites - 12.25oz/12ct","22"],
  ["218-13-0587","Egg Shaped Cake Pop - 3ct","11"],
  ["218-13-0286","Egg Shaped Cake Pop - 1ct","11"],
  ["218-13-0605","Strawberry Mini Muffins - 9ct","13"],
  ["218-13-0606","Strawberry Mini Muffin - 12ct","15"],
  ["218-13-0607","Double Berry Mini Muffins - 9ct","13"],
  ["218-13-0593","Chocolate Chip Snack Bites - 8ct / 8oz","45"],
  ["218-13-0575","Pastel Rainbow White Chocolate Drops with White Nonpareils - 4oz","Prelabeled"],
  ["218-13-0576","Enrobed White Pretzel Rainbow NP - 4oz","Prelabeled"],
  ["218-13-0577","Enrobed Pink with Yellow Drizzle Pretzel - 4oz","Prelabeled"],
  ["218-13-0578","Milk Chocolate Enrobed Graham with Rainbow Quins - 4oz","Prelabeled"],
];

let currentFilter = 'all';
let highlightedDpci = null;

function dayClass(val) {
  if (val === 'Prelabeled') return 'pre';
  const n = parseInt(val);
  if (n <= 7) return 'short';
  if (n <= 30) return 'medium';
  return 'long';
}

function filterData(filter) {
  return DATA.filter(([dpci, name, days]) => {
    if (filter === 'all') return true;
    if (filter === 'prelabeled') return days === 'Prelabeled';
    const n = parseInt(days);
    if (isNaN(n)) return false;
    if (filter === 'short') return n <= 7;
    if (filter === 'medium') return n >= 8 && n <= 30;
    if (filter === 'long') return n > 30;
    return true;
  });
}

function renderTable(filter, searchQuery) {
  let rows = filterData(filter);

  // If there's a search query, further filter by name or dpci
  if (searchQuery && searchQuery.length > 0) {
    const q = searchQuery.toLowerCase().replace(/-/g, '');
    rows = rows.filter(([dpci, name]) =>
      dpci.replace(/-/g,'').includes(q) || name.toLowerCase().includes(q)
    );
  }

  const tbody = document.getElementById('tableBody');
  const noResults = document.getElementById('noResults');
  const countBadge = document.getElementById('countBadge');

  tbody.innerHTML = '';
  countBadge.textContent = `${rows.length} item${rows.length !== 1 ? 's' : ''}`;

  if (rows.length === 0) {
    noResults.style.display = 'block';
    return;
  }
  noResults.style.display = 'none';

  rows.forEach(([dpci, name, days]) => {
    const tr = document.createElement('tr');
    if (dpci === highlightedDpci) tr.classList.add('highlighted');
    tr.innerHTML = `
      <td class="td-dpci">${dpci}</td>
      <td class="td-name">${name}</td>
      <td class="td-days ${dayClass(days)}">${days === 'Prelabeled' ? 'PRELABELED' : days + ' d'}</td>
    `;
    tr.addEventListener('click', () => fillSearch(dpci));
    tbody.appendChild(tr);
  });
}

function fillSearch(dpci) {
  document.getElementById('searchInput').value = dpci;
  handleSearch(dpci);
}

function setFilter(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const q = document.getElementById('searchInput').value.trim();
  renderTable(currentFilter, q.length >= 3 ? '' : '');
}

function handleSearch(val) {
  const q = val.trim().replace(/-/g, '').toLowerCase();
  const card = document.getElementById('resultCard');
  const icon = document.getElementById('searchIcon');
  const clearBtn = document.getElementById('clearBtn');

  if (val.length > 0) {
    clearBtn.style.display = 'block';
    icon.style.display = 'none';
  } else {
    clearBtn.style.display = 'none';
    icon.style.display = 'block';
  }

  if (q.length < 3) {
    card.style.display = 'none';
    highlightedDpci = null;
    renderTable(currentFilter, '');
    return;
  }

  // exact DPCI match first
  const exact = DATA.find(([dpci]) => dpci.replace(/-/g,'').toLowerCase() === q);
  if (exact) {
    showResult(exact, true);
    highlightedDpci = exact[0];
    renderTable(currentFilter, '');
    return;
  }

  // partial match
  const partial = DATA.filter(([dpci, name]) =>
    dpci.replace(/-/g,'').toLowerCase().includes(q) || name.toLowerCase().includes(q)
  );

  if (partial.length === 1) {
    showResult(partial[0], true);
    highlightedDpci = partial[0][0];
    renderTable(currentFilter, '');
  } else if (partial.length > 1) {
    card.style.display = 'none';
    highlightedDpci = null;
    renderTable(currentFilter, val.trim());
  } else {
    showNotFound(val.trim());
    highlightedDpci = null;
    renderTable(currentFilter, val.trim());
  }
}

function showResult([dpci, name, days], found) {
  const card = document.getElementById('resultCard');
  document.getElementById('resultDpci').textContent = dpci;
  document.getElementById('resultName').textContent = name;

  const shelfEl = document.getElementById('resultShelf');
  if (days === 'Prelabeled') {
    shelfEl.innerHTML = `<div class="prelabeled-badge">🏷 Prelabeled — check packaging for date</div>`;
  } else {
    const cls = dayClass(days);
    const color = cls === 'short' ? 'var(--red)' : cls === 'medium' ? 'var(--accent)' : 'var(--green)';
    shelfEl.innerHTML = `
      <div class="shelf-display">
        <div class="shelf-num" style="color:${color}">${days}</div>
        <div class="shelf-label">
          <div class="big">day${parseInt(days) !== 1 ? 's' : ''} shelf life</div>
          <div class="small">from production date</div>
        </div>
      </div>`;
  }

  card.className = 'result-card found';
  card.style.display = 'block';
}

function showNotFound(val) {
  const card = document.getElementById('resultCard');
  document.getElementById('resultDpci').textContent = val;
  document.getElementById('resultName').textContent = '';
  document.getElementById('resultShelf').innerHTML = `
    <div class="not-found-msg">
      <span class="icon">⚠️</span>
      <span>No item found for this DPCI. Double-check the number.</span>
    </div>`;
  card.className = 'result-card not-found';
  card.style.display = 'block';
}

function clearSearch() {
  document.getElementById('searchInput').value = '';
  document.getElementById('resultCard').style.display = 'none';
  document.getElementById('clearBtn').style.display = 'none';
  document.getElementById('searchIcon').style.display = 'block';
  highlightedDpci = null;
  renderTable(currentFilter, '');
  document.getElementById('searchInput').focus();
}

// init
document.getElementById('searchInput').addEventListener('input', e => handleSearch(e.target.value));
document.getElementById('searchInput').addEventListener('keydown', e => {
  if (e.key === 'Escape') clearSearch();
});

renderTable('all', '');
</script>

